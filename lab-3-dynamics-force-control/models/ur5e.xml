<mujoco model="ur5e_lab3_torque">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="1.0" armature="0.01" limited="true"/>
    <geom rgba="0.33 0.47 0.58 1" density="800" contype="1" conaffinity="1"/>
    <motor ctrllimited="true" ctrlrange="-180 180"/>
  </default>

  <worldbody>
    <geom type="plane" size="2 2 0.1" rgba="0.92 0.92 0.92 1"/>
    <body name="base" pos="0 0 0">
      <geom type="cylinder" size="0.09 0.06" rgba="0.20 0.20 0.20 1"/>
      <body name="shoulder" pos="0 0 0.1625" euler="0 0 0">
        <joint name="shoulder_pan_joint" axis="0 0 1" range="-6.28318530718 6.28318530718"/>
        <geom type="box" size="0.06 0.06 0.09"/>
        <body name="upper_arm" pos="0 0 0" euler="1.57079632679 0 0">
          <joint name="shoulder_lift_joint" axis="0 0 1" range="-6.28318530718 6.28318530718"/>
          <geom type="capsule" fromto="0 0 0 -0.425 0 0" size="0.055"/>
          <body name="forearm" pos="-0.425 0 0" euler="0 0 0">
            <joint name="elbow_joint" axis="0 0 1" range="-6.28318530718 6.28318530718"/>
            <geom type="capsule" fromto="0 0 0 -0.3922 0 0.1333" size="0.05"/>
            <body name="wrist_1" pos="-0.3922 0 0.1333" euler="0 0 0">
              <joint name="wrist_1_joint" axis="0 0 1" range="-6.28318530718 6.28318530718"/>
              <geom type="capsule" fromto="0 0 0 0 0 0.0997" size="0.045"/>
              <body name="wrist_2" pos="0 0 0.0997" euler="1.57079632679 0 0">
                <joint name="wrist_2_joint" axis="0 0 1" range="-6.28318530718 6.28318530718"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.0996" size="0.04"/>
                <body name="wrist_3" pos="0 0 0.0996" euler="-1.57079632679 0 0">
                  <joint name="wrist_3_joint" axis="0 0 1" range="-6.28318530718 6.28318530718"/>
                  <geom type="capsule" fromto="0 0 0 0 0 0.135" size="0.035"/>
                  <body name="tool0" pos="0 0 0.135">
                    <geom type="box" size="0.015 0.015 0.0675" rgba="0.20 0.20 0.20 1"/>
                    <!-- Probe tip for table contact (contype=2 matches table conaffinity=2) -->
                    <geom name="probe_tip" type="sphere" size="0.01" pos="0 0 0"
                          contype="2" conaffinity="2" rgba="1 0.2 0.2 0.8"
                          density="0" mass="0"/>
                    <site name="tool_site" pos="0 0 0" size="0.012" rgba="1 0.2 0.2 1"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="shoulder_pan_joint"/>
    <motor name="motor2" joint="shoulder_lift_joint"/>
    <motor name="motor3" joint="elbow_joint"/>
    <motor name="motor4" joint="wrist_1_joint"/>
    <motor name="motor5" joint="wrist_2_joint"/>
    <motor name="motor6" joint="wrist_3_joint"/>
  </actuator>
</mujoco>
