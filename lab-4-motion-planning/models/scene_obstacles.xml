<mujoco model="ur5e_lab4_obstacles">
  <!--
    Lab 4 Scene: UR5e with torque-mode actuators + obstacle boxes.
    Obstacles create narrow passages for motion planning demos.
  -->
  <include file="ur5e.xml"/>

  <statistic center="0.3 0 0.4" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-25" offwidth="1920" offheight="1080"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
      width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
      width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
      texrepeat="5 5" reflectance="0.2"/>
    <material name="obstacle" rgba="0.85 0.25 0.20 0.9"/>
    <material name="table_wood" rgba="0.55 0.35 0.20 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <light pos="1.5 -1.5 2.0" dir="-0.5 0.5 -1" directional="false"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table surface (near edge at x=0.15, far enough from robot base) -->
    <body name="table" pos="0.45 0.0 0.3">
      <geom name="table_top" type="box" size="0.30 0.45 0.015" material="table_wood"/>
      <!-- Legs (visual only) -->
      <geom type="cylinder" pos="-0.30 -0.40 -0.15" size="0.02 0.135" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="0.30 -0.40 -0.15" size="0.02 0.135" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="-0.30 0.40 -0.15" size="0.02 0.135" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="0.30 0.40 -0.15" size="0.02 0.135" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
    </body>

    <!-- Obstacle 1: tall box on left side of table -->
    <body name="obstacle_1" pos="0.30 0.15 0.415">
      <geom name="obs1" type="box" size="0.06 0.06 0.10" material="obstacle"/>
    </body>

    <!-- Obstacle 2: tall box on right side -->
    <body name="obstacle_2" pos="0.30 -0.15 0.415">
      <geom name="obs2" type="box" size="0.06 0.06 0.10" material="obstacle"/>
    </body>

    <!-- Obstacle 3: wide wall in center, creating a narrow passage -->
    <body name="obstacle_3" pos="0.45 0.0 0.375">
      <geom name="obs3" type="box" size="0.04 0.12 0.06" material="obstacle"/>
    </body>

    <!-- Obstacle 4: box near goal side -->
    <body name="obstacle_4" pos="0.55 0.12 0.395">
      <geom name="obs4" type="box" size="0.05 0.05 0.08" material="obstacle"/>
    </body>
  </worldbody>
</mujoco>
