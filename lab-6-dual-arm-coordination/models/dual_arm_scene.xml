<mujoco model="lab6_dual_arm">
  <!--
    Lab 6: Dual-Arm Coordination Scene

    Two UR5e arms with parallel-jaw grippers cooperatively carry a large bar.

    Layout:
      - Left arm base: (0, -0.35, 0)  — grips bar -Y end at ~(0.45, -0.10, bar_z)
      - Right arm base: (0,  0.35, 0) — grips bar +Y end at ~(0.45, +0.10, bar_z)
      - Table centre: (0.45, 0, 0.300), top at z = 0.315
      - carry_bar centre: (0.45, 0, 0.335), half_extents (0.025, 0.12, 0.020)
        → bar is 50 mm wide in X, 240 mm long in Y, 40 mm tall in Z
        → each arm grips one Y-end; arms stay on their own side (no crossing)

    Gripper orientation:
      - gripper_base is rotated 90° about tool0 Z (euler="0 0 1.5708")
      - fingers now slide along world X at Q_HOME (not world Y)
      - bar is thin in X (50 mm); fingers straddle ±25 mm of bar in X

    Actuator layout (14 total):
      ctrl[0-5]  : left arm torque motors (shoulder_pan … wrist_3)
      ctrl[6]    : left gripper position actuator
      ctrl[7-12] : right arm torque motors
      ctrl[13]   : right gripper position actuator

    qpos layout (23 total):
      qpos[0-5]  : left arm joints
      qpos[6]    : left_left_finger_joint
      qpos[7]    : left_right_finger_joint  (mirrored by equality)
      qpos[8-13] : right arm joints
      qpos[14]   : right_left_finger_joint
      qpos[15]   : right_right_finger_joint (mirrored by equality)
      qpos[16-22]: carry_bar freejoint (3 pos + 4 quat)

    Coordinate convention:
      - top-down gripper: tool0 local Z = approach direction (world -Z at Q_HOME)
      - fingers slide along world X (after 90° gripper rotation about tool0 Z)
      - ctrl[grip] = 0.030 → open (60 mm gap in X)
      - ctrl[grip] = 0.000 → closed
  -->

  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="1.0" armature="0.01" limited="true"/>
    <geom rgba="0.33 0.47 0.58 1" density="800" contype="1" conaffinity="1"/>
    <motor ctrllimited="true" ctrlrange="-180 180"/>
  </default>

  <statistic center="0.45 0 0.5" extent="1.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="130" elevation="-20" offwidth="1920" offheight="1080"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat"  rgba="0.75 0.60 0.40 1"/>
    <material name="bar_mat"    rgba="0.85 0.30 0.10 1"/>
    <material name="target_mat" rgba="0.10 0.80 0.20 0.4"/>
    <material name="left_arm_mat"  rgba="0.20 0.45 0.70 1"/>
    <material name="right_arm_mat" rgba="0.70 0.30 0.20 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3.0" dir="0 0 -1" directional="true"/>
    <light pos="1.5 -1.5 2.5" dir="-0.5 0.5 -1" directional="false"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- =====================================================================
         LEFT ARM  (base at y = -0.35)
         All body/joint/geom/site names prefixed with "left_"
         ===================================================================== -->
    <body name="left_base" pos="0 -0.35 0">
      <geom name="left_base_geom" type="cylinder" size="0.09 0.06"
            rgba="0.15 0.35 0.60 1"/>
      <body name="left_shoulder" pos="0 0 0.1625">
        <joint name="left_shoulder_pan_joint" axis="0 0 1"
               range="-6.28318530718 6.28318530718"/>
        <geom name="left_shoulder_geom" type="box" size="0.06 0.06 0.09"
              rgba="0.20 0.45 0.70 1"/>
        <body name="left_upper_arm" pos="0 0 0" euler="1.57079632679 0 0">
          <joint name="left_shoulder_lift_joint" axis="0 0 1"
                 range="-6.28318530718 6.28318530718"/>
          <geom name="left_upper_arm_geom" type="capsule"
                fromto="0 0 0 -0.425 0 0" size="0.055" rgba="0.20 0.45 0.70 1"/>
          <body name="left_forearm" pos="-0.425 0 0">
            <joint name="left_elbow_joint" axis="0 0 1"
                   range="-6.28318530718 6.28318530718"/>
            <geom name="left_forearm_geom" type="capsule"
                  fromto="0 0 0 -0.3922 0 0.1333" size="0.050"
                  rgba="0.20 0.45 0.70 1"/>
            <body name="left_wrist_1" pos="-0.3922 0 0.1333">
              <joint name="left_wrist_1_joint" axis="0 0 1"
                     range="-6.28318530718 6.28318530718"/>
              <geom name="left_wrist_1_geom" type="capsule"
                    fromto="0 0 0 0 0 0.0997" size="0.045"
                    rgba="0.20 0.45 0.70 1"/>
              <body name="left_wrist_2" pos="0 0 0.0997"
                    euler="1.57079632679 0 0">
                <joint name="left_wrist_2_joint" axis="0 0 1"
                       range="-6.28318530718 6.28318530718"/>
                <geom name="left_wrist_2_geom" type="capsule"
                      fromto="0 0 0 0 0 0.0996" size="0.040"
                      rgba="0.20 0.45 0.70 1"/>
                <body name="left_wrist_3" pos="0 0 0.0996"
                      euler="-1.57079632679 0 0">
                  <joint name="left_wrist_3_joint" axis="0 0 1"
                         range="-6.28318530718 6.28318530718"/>
                  <geom name="left_wrist_3_geom" type="capsule"
                        fromto="0 0 0 0 0 0.135" size="0.035"
                        rgba="0.20 0.45 0.70 1"/>

                  <!-- tool0 flange -->
                  <body name="left_tool0" pos="0 0 0.135">
                    <site name="left_tool_site" pos="0 0 0" size="0.010"
                          rgba="0.2 0.6 1 1"/>

                    <!-- Gripper adapter plate — rotated 90° about Z so fingers close in world X -->
                    <body name="left_gripper_base" pos="0 0 0.020" euler="0 0 1.5708">
                      <geom name="left_gripper_adapter" type="box"
                            size="0.035 0.035 0.020"
                            rgba="0.10 0.10 0.10 1" mass="0.08"/>

                      <!-- Left finger of left arm -->
                      <body name="left_left_finger" pos="0 0.015 0.060">
                        <joint name="left_left_finger_joint" type="slide"
                               axis="0 1 0" range="0 0.030"
                               damping="2.0" armature="0.0001"/>
                        <geom name="left_left_finger_geom" type="box"
                              size="0.013 0.008 0.025"
                              rgba="0.1 0.7 0.2 1" mass="0.02"/>
                        <geom name="left_left_pad" type="box"
                              size="0.010 0.005 0.008"
                              pos="0 0.009 0.025"
                              friction="1.5 0.005 0.0001"
                              solimp="0.99 0.99 0.001"
                              solref="0.002 1"
                              condim="4"
                              rgba="0.05 0.5 0.1 1"
                              mass="0.005"/>
                      </body>

                      <!-- Right finger of left arm -->
                      <body name="left_right_finger" pos="0 -0.015 0.060">
                        <joint name="left_right_finger_joint" type="slide"
                               axis="0 -1 0" range="0 0.030"
                               damping="2.0" armature="0.0001"/>
                        <geom name="left_right_finger_geom" type="box"
                              size="0.013 0.008 0.025"
                              rgba="0.1 0.7 0.2 1" mass="0.02"/>
                        <geom name="left_right_pad" type="box"
                              size="0.010 0.005 0.008"
                              pos="0 -0.009 0.025"
                              friction="1.5 0.005 0.0001"
                              solimp="0.99 0.99 0.001"
                              solref="0.002 1"
                              condim="4"
                              rgba="0.05 0.5 0.1 1"
                              mass="0.005"/>
                      </body>

                      <!-- Fingertip center site for IK -->
                      <site name="left_gripper_site" pos="0 0 0.090"
                            size="0.008" rgba="0.2 1 0.5 1"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- =====================================================================
         RIGHT ARM  (base at y = +0.35)
         All body/joint/geom/site names prefixed with "right_"
         ===================================================================== -->
    <body name="right_base" pos="0 0.35 0">
      <geom name="right_base_geom" type="cylinder" size="0.09 0.06"
            rgba="0.55 0.20 0.15 1"/>
      <body name="right_shoulder" pos="0 0 0.1625">
        <joint name="right_shoulder_pan_joint" axis="0 0 1"
               range="-6.28318530718 6.28318530718"/>
        <geom name="right_shoulder_geom" type="box" size="0.06 0.06 0.09"
              rgba="0.70 0.30 0.20 1"/>
        <body name="right_upper_arm" pos="0 0 0" euler="1.57079632679 0 0">
          <joint name="right_shoulder_lift_joint" axis="0 0 1"
                 range="-6.28318530718 6.28318530718"/>
          <geom name="right_upper_arm_geom" type="capsule"
                fromto="0 0 0 -0.425 0 0" size="0.055"
                rgba="0.70 0.30 0.20 1"/>
          <body name="right_forearm" pos="-0.425 0 0">
            <joint name="right_elbow_joint" axis="0 0 1"
                   range="-6.28318530718 6.28318530718"/>
            <geom name="right_forearm_geom" type="capsule"
                  fromto="0 0 0 -0.3922 0 0.1333" size="0.050"
                  rgba="0.70 0.30 0.20 1"/>
            <body name="right_wrist_1" pos="-0.3922 0 0.1333">
              <joint name="right_wrist_1_joint" axis="0 0 1"
                     range="-6.28318530718 6.28318530718"/>
              <geom name="right_wrist_1_geom" type="capsule"
                    fromto="0 0 0 0 0 0.0997" size="0.045"
                    rgba="0.70 0.30 0.20 1"/>
              <body name="right_wrist_2" pos="0 0 0.0997"
                    euler="1.57079632679 0 0">
                <joint name="right_wrist_2_joint" axis="0 0 1"
                       range="-6.28318530718 6.28318530718"/>
                <geom name="right_wrist_2_geom" type="capsule"
                      fromto="0 0 0 0 0 0.0996" size="0.040"
                      rgba="0.70 0.30 0.20 1"/>
                <body name="right_wrist_3" pos="0 0 0.0996"
                      euler="-1.57079632679 0 0">
                  <joint name="right_wrist_3_joint" axis="0 0 1"
                         range="-6.28318530718 6.28318530718"/>
                  <geom name="right_wrist_3_geom" type="capsule"
                        fromto="0 0 0 0 0 0.135" size="0.035"
                        rgba="0.70 0.30 0.20 1"/>

                  <!-- tool0 flange -->
                  <body name="right_tool0" pos="0 0 0.135">
                    <site name="right_tool_site" pos="0 0 0" size="0.010"
                          rgba="1 0.4 0.2 1"/>

                    <!-- Gripper adapter plate — rotated 90° about Z so fingers close in world X -->
                    <body name="right_gripper_base" pos="0 0 0.020" euler="0 0 1.5708">
                      <geom name="right_gripper_adapter" type="box"
                            size="0.035 0.035 0.020"
                            rgba="0.10 0.10 0.10 1" mass="0.08"/>

                      <!-- Left finger of right arm -->
                      <body name="right_left_finger" pos="0 0.015 0.060">
                        <joint name="right_left_finger_joint" type="slide"
                               axis="0 1 0" range="0 0.030"
                               damping="2.0" armature="0.0001"/>
                        <geom name="right_left_finger_geom" type="box"
                              size="0.013 0.008 0.025"
                              rgba="0.9 0.5 0.1 1" mass="0.02"/>
                        <geom name="right_left_pad" type="box"
                              size="0.010 0.005 0.008"
                              pos="0 0.009 0.025"
                              friction="1.5 0.005 0.0001"
                              solimp="0.99 0.99 0.001"
                              solref="0.002 1"
                              condim="4"
                              rgba="0.7 0.4 0.05 1"
                              mass="0.005"/>
                      </body>

                      <!-- Right finger of right arm -->
                      <body name="right_right_finger" pos="0 -0.015 0.060">
                        <joint name="right_right_finger_joint" type="slide"
                               axis="0 -1 0" range="0 0.030"
                               damping="2.0" armature="0.0001"/>
                        <geom name="right_right_finger_geom" type="box"
                              size="0.013 0.008 0.025"
                              rgba="0.9 0.5 0.1 1" mass="0.02"/>
                        <geom name="right_right_pad" type="box"
                              size="0.010 0.005 0.008"
                              pos="0 -0.009 0.025"
                              friction="1.5 0.005 0.0001"
                              solimp="0.99 0.99 0.001"
                              solref="0.002 1"
                              condim="4"
                              rgba="0.7 0.4 0.05 1"
                              mass="0.005"/>
                      </body>

                      <!-- Fingertip center site for IK -->
                      <site name="right_gripper_site" pos="0 0 0.090"
                            size="0.008" rgba="1 0.8 0.2 1"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- =====================================================================
         TABLE  (surface at z = 0.315)
         ===================================================================== -->
    <body name="table" pos="0.45 0 0.300">
      <geom name="table_top" type="box" size="0.35 0.50 0.015"
            material="table_mat" contype="1" conaffinity="1"
            friction="0.8 0.005 0.0001"/>
      <geom name="table_leg_fl" type="box" size="0.025 0.025 0.300"
            pos="-0.30  0.45 -0.300" rgba="0.6 0.5 0.3 1"/>
      <geom name="table_leg_fr" type="box" size="0.025 0.025 0.300"
            pos="-0.30 -0.45 -0.300" rgba="0.6 0.5 0.3 1"/>
      <geom name="table_leg_bl" type="box" size="0.025 0.025 0.300"
            pos=" 0.30  0.45 -0.300" rgba="0.6 0.5 0.3 1"/>
      <geom name="table_leg_br" type="box" size="0.025 0.025 0.300"
            pos=" 0.30 -0.45 -0.300" rgba="0.6 0.5 0.3 1"/>
    </body>

    <!-- =====================================================================
         CARRY BAR  (the cooperative carry object)
         Centre: (0.45, 0, 0.335)
         Half-extents: x=0.025 (50 mm), y=0.12 (240 mm), z=0.020 (40 mm)
         Bar is Y-oriented: each arm grips one Y-end from its own side
         Mass: 0.6 kg  — heavy enough to need two arms
         ===================================================================== -->
    <body name="carry_bar" pos="0.45 0 0.335">
      <freejoint name="bar_joint"/>
      <geom name="bar_geom" type="box"
            size="0.025 0.12 0.020"
            material="bar_mat"
            mass="0.60"
            friction="1.5 0.005 0.0001"
            solimp="0.99 0.99 0.001"
            solref="0.002 1"
            condim="4"
            contype="1" conaffinity="1"/>
    </body>

    <!-- Target pad: visual marker for place position (matches Y-oriented bar) -->
    <body name="target_pad" pos="0.45 0.20 0.316">
      <geom name="target_geom" type="box"
            size="0.030 0.13 0.001"
            material="target_mat"
            contype="0" conaffinity="0"/>
    </body>

  </worldbody>

  <!-- Mirror finger joints for each arm -->
  <equality>
    <joint name="left_finger_mirror"
           joint1="left_left_finger_joint"
           joint2="left_right_finger_joint"
           polycoef="0 1 0 0 0"/>
    <joint name="right_finger_mirror"
           joint1="right_left_finger_joint"
           joint2="right_right_finger_joint"
           polycoef="0 1 0 0 0"/>
  </equality>

  <actuator>
    <!-- Left arm torque-controlled motors (ctrl[0-5]) -->
    <motor name="left_motor1" joint="left_shoulder_pan_joint"/>
    <motor name="left_motor2" joint="left_shoulder_lift_joint"/>
    <motor name="left_motor3" joint="left_elbow_joint"/>
    <motor name="left_motor4" joint="left_wrist_1_joint"/>
    <motor name="left_motor5" joint="left_wrist_2_joint"/>
    <motor name="left_motor6" joint="left_wrist_3_joint"/>
    <!-- Left gripper position actuator (ctrl[6]) -->
    <position name="left_gripper" joint="left_left_finger_joint"
              kp="200" ctrllimited="true" ctrlrange="0 0.030"/>

    <!-- Right arm torque-controlled motors (ctrl[7-12]) -->
    <motor name="right_motor1" joint="right_shoulder_pan_joint"/>
    <motor name="right_motor2" joint="right_shoulder_lift_joint"/>
    <motor name="right_motor3" joint="right_elbow_joint"/>
    <motor name="right_motor4" joint="right_wrist_1_joint"/>
    <motor name="right_motor5" joint="right_wrist_2_joint"/>
    <motor name="right_motor6" joint="right_wrist_3_joint"/>
    <!-- Right gripper position actuator (ctrl[13]) -->
    <position name="right_gripper" joint="right_left_finger_joint"
              kp="200" ctrllimited="true" ctrlrange="0 0.030"/>
  </actuator>

</mujoco>
