<mujoco model="g1_scene_flat">
  <!--
    Scene: G1 humanoid on flat ground with lighting and camera.
    Includes g1_humanoid.xml which defines the robot model.
  -->

  <include file="g1_humanoid.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0.2 0.2 0.2"/>
    <quality shadowsize="4096"/>
    <map znear="0.01" zfar="50"/>
  </visual>

  <worldbody>
    <!-- Ground plane -->
    <geom name="ground" type="plane" size="10 10 0.05"
          rgba="0.85 0.85 0.80 1" contype="1" conaffinity="1"
          condim="3" friction="0.8 0.005 0.0001"/>

    <!-- Lighting -->
    <light name="top_light" pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"
           specular="0.3 0.3 0.3" directional="true"/>
    <light name="front_light" pos="2 -2 3" dir="-0.5 0.5 -0.7"
           diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>

    <!-- Camera definitions -->
    <camera name="tracking" mode="trackcom" pos="2 -2 1.5"/>
    <camera name="side" pos="2 0 0.8" xyaxes="0 1 0 0 0 1" mode="fixed"/>
    <camera name="front" pos="0 -2.5 0.8" xyaxes="1 0 0 0 0 1" mode="fixed"/>
  </worldbody>
</mujoco>
