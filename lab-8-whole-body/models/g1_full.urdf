  </joint>

  <link name="right_wrist_roll_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
    <visual><geometry><sphere radius="0.025"/></geometry></visual>
    <collision><geometry><sphere radius="0.025"/></geometry></collision>
  </link>
  <joint name="right_wrist_roll" type="revolute">
    <parent link="right_elbow_link"/>
    <child link="right_wrist_roll_link"/>
    <origin xyz="0 0 -0.22" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="8.0"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>

  <link name="right_hand">
    <inertial>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.08 0.06 0.12"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
      <geometry><box size="0.08 0.06 0.12"/></geometry>
    </collision>
  </link>
  <joint name="right_wrist_pitch" type="revolute">
    <parent link="right_wrist_roll_link"/>
    <child link="right_hand"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="8.0"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>

  <!-- ===== HEAD ===== -->
  <link name="head">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
    <visual><geometry><sphere radius="0.1"/></geometry></visual>
    <collision><geometry><sphere radius="0.1"/></geometry></collision>
  </link>
  <joint name="head_fixed" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0.23" rpy="0 0 0"/>
  </joint>

</robot>
