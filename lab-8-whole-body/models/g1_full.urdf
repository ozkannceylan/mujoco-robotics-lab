<?xml version="1.0" encoding="UTF-8"?>
<!--
  Unitree G1 Humanoid - Full Body URDF for Pinocchio
  Lab 8: Whole-Body Loco-Manipulation

  Root joint type: freeflyer (set in code via pin.buildModelFromUrdf with freeflyer)

  Joint ordering (after freeflyer, 0-indexed from first actuated):
    0:  waist_yaw
    1:  left_hip_yaw
    2:  left_hip_roll
    3:  left_hip_pitch
    4:  left_knee
    5:  left_ankle_pitch
    6:  left_ankle_roll
    7:  right_hip_yaw
    8:  right_hip_roll
    9:  right_hip_pitch
    10: right_knee
    11: right_ankle_pitch
    12: right_ankle_roll
    13: left_shoulder_pitch
    14: left_shoulder_roll
    15: left_shoulder_yaw
    16: left_elbow
    17: left_wrist_roll
    18: left_wrist_pitch
    19: right_shoulder_pitch
    20: right_shoulder_roll
    21: right_shoulder_yaw
    22: right_elbow
    23: right_wrist_roll
    24: right_wrist_pitch
-->
<robot name="g1_full">

  <!-- ========== LINKS ========== -->

  <link name="torso">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.06" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.24 0.14 0.36"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.24 0.14 0.36"/></geometry>
    </collision>
  </link>

  <!-- Waist -->
  <link name="waist">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.08"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.08"/></geometry>
    </collision>
  </link>
  <joint name="waist_yaw" type="revolute">
    <parent link="torso"/>
    <child link="waist"/>
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="5.0"/>
    <dynamics damping="8.0" friction="0.1"/>
  </joint>

  <!-- ===== LEFT LEG ===== -->
  <link name="left_hip_yaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.04"/></geometry>
    </visual>
    <collision>
      <geometry><sphere radius="0.04"/></geometry>
    </collision>
  </link>
  <joint name="left_hip_yaw" type="revolute">
    <parent link="waist"/>
    <child link="left_hip_yaw_link"/>
    <origin xyz="0 0.09 -0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.43" upper="0.43" effort="150" velocity="5.0"/>
    <dynamics damping="8.0" friction="0.1"/>
  </joint>

  <link name="left_hip_roll_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.04"/></geometry>
    </visual>
    <collision>
      <geometry><sphere radius="0.04"/></geometry>
    </collision>
  </link>
  <joint name="left_hip_roll" type="revolute">
    <parent link="left_hip_yaw_link"/>
    <child link="left_hip_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.43" upper="1.57" effort="150" velocity="5.0"/>
    <dynamics damping="8.0" friction="0.1"/>
  </joint>

  <link name="left_hip_pitch_link">
    <inertial>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <mass value="3.5"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry>
    </collision>
  </link>
  <joint name="left_hip_pitch" type="revolute">
    <parent link="left_hip_roll_link"/>
    <child link="left_hip_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="200" velocity="5.0"/>
    <dynamics damping="10.0" friction="0.1"/>
  </joint>

  <link name="left_knee_link">
    <inertial>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <mass value="2.5"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.28"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.28"/></geometry>
    </collision>
  </link>
  <joint name="left_knee" type="revolute">
    <parent link="left_hip_pitch_link"/>
    <child link="left_knee_link"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.26" upper="2.53" effort="200" velocity="5.0"/>
    <dynamics damping="10.0" friction="0.1"/>
  </joint>

  <link name="left_ankle_pitch_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.035"/></geometry>
    </visual>
    <collision>
      <geometry><sphere radius="0.035"/></geometry>
    </collision>
  </link>
  <joint name="left_ankle_pitch" type="revolute">
    <parent link="left_knee_link"/>
    <child link="left_ankle_pitch_link"/>
    <origin xyz="0 0 -0.28" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.87" upper="0.52" effort="100" velocity="5.0"/>
    <dynamics damping="5.0" friction="0.1"/>
  </joint>

  <link name="left_ankle_roll_link">
    <inertial>
      <origin xyz="0.03 0 -0.03" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.003"/>
    </inertial>
    <visual>
      <origin xyz="0.03 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.24 0.12 0.04"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.03 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.24 0.12 0.04"/></geometry>
    </collision>
  </link>
  <joint name="left_ankle_roll" type="revolute">
    <parent link="left_ankle_pitch_link"/>
    <child link="left_ankle_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.26" upper="0.26" effort="75" velocity="5.0"/>
    <dynamics damping="3.0" friction="0.1"/>
  </joint>

  <!-- ===== RIGHT LEG ===== -->
  <link name="right_hip_yaw_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
