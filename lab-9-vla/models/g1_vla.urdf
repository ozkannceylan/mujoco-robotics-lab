<?xml version="1.0" encoding="utf-8"?>
<!-- G1 Humanoid Robot URDF for VLA Integration Lab 9
     Used by Pinocchio for analytical kinematics/dynamics computations.
     Matches the MJCF structure but uses URDF format.
     ~25 actuated DOF upper-body + legs configuration.
-->
<robot name="g1_vla">

  <!-- Base link (pelvis) -->
  <link name="pelvis">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.03"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.24 0.16 0.20"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.24 0.16 0.20"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- Torso -->
  <link name="torso">
    <inertial>
      <mass value="12.0"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.15" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.08"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.24 0.16 0.40"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.24 0.16 0.40"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="torso_yaw" type="revolute">
    <parent link="pelvis"/>
    <child link="torso"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="80.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Head -->
  <link name="head">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.008"/>
    </inertial>
    <visual>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="head_pitch" type="revolute">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6" upper="0.6" effort="20.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left Shoulder Roll -->
  <link name="left_shoulder_roll">
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 0.04 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 0.04 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="left_shoulder_roll" type="revolute">
    <parent link="torso"/>
    <child link="left_shoulder_roll"/>
    <origin xyz="0.0 0.18 0.25" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="80.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left Shoulder Pitch -->
  <link name="left_shoulder_pitch">
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 0.04 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 0.04 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="left_shoulder_pitch" type="revolute">
    <parent link="left_shoulder_roll"/>
    <child link="left_shoulder_pitch"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="80.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left Upper Arm -->
  <link name="left_upper_arm">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0.05 0" rpy="0 0 0"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 0.05 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 0.05 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="left_shoulder_yaw" type="revolute">
    <parent link="left_shoulder_pitch"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="40.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left Forearm -->
  <link name="left_forearm">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0.05 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 0.05 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 0.05 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="left_elbow" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_forearm"/>
    <origin xyz="0 0.25 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.0" effort="40.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left Wrist -->
  <link name="left_wrist">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0.03 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
      <origin xyz="0 0.03 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
      <origin xyz="0 0.03 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="left_wrist_roll" type="revolute">
    <parent link="left_forearm"/>
    <child link="left_wrist"/>
    <origin xyz="0 0.22 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="15.0" velocity="5.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left Hand -->
  <link name="left_hand">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.08 0.10 0.04"/>
      </geometry>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.10 0.04"/>
      </geometry>
      <origin xyz="0 0.04 0" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="left_wrist_pitch" type="revolute">
    <parent link="left_wrist"/>
    <child link="left_hand"/>
    <origin xyz="0 0.06 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="15.0" velocity="5.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Left EE (fixed frame at fingertips) -->
  <link name="left_ee"/>
  <joint name="left_ee_joint" type="fixed">
    <parent link="left_hand"/>
    <child link="left_ee"/>
    <origin xyz="0 0.14 0" rpy="0 0 0"/>
  </joint>

  <!-- Right Shoulder Roll -->
  <link name="right_shoulder_roll">
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 -0.04 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="right_shoulder_roll" type="revolute">
    <parent link="torso"/>
    <child link="right_shoulder_roll"/>
    <origin xyz="0.0 -0.18 0.25" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="80.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Right Shoulder Pitch -->
  <link name="right_shoulder_pitch">
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 -0.04 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.10"/>
      </geometry>
      <origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="right_shoulder_pitch" type="revolute">
    <parent link="right_shoulder_roll"/>
    <child link="right_shoulder_pitch"/>
    <origin xyz="0 -0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="80.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Right Upper Arm -->
  <link name="right_upper_arm">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 -0.05 0" rpy="0 0 0"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 -0.05 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 -0.05 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="right_shoulder_yaw" type="revolute">
    <parent link="right_shoulder_pitch"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 -0.08 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="40.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Right Forearm -->
  <link name="right_forearm">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 -0.05 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 -0.05 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.20"/>
      </geometry>
      <origin xyz="0 -0.05 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="right_elbow" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_forearm"/>
    <origin xyz="0 -0.25 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="2.0" effort="40.0" velocity="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Right Wrist -->
  <link name="right_wrist">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 -0.03 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
      <origin xyz="0 -0.03 0" rpy="1.5708 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.10"/>
      </geometry>
      <origin xyz="0 -0.03 0" rpy="1.5708 0 0"/>
    </collision>
  </link>

  <joint name="right_wrist_roll" type="revolute">
    <parent link="right_forearm"/>
    <child link="right_wrist"/>
    <origin xyz="0 -0.22 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="15.0" velocity="5.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Right Hand -->
  <link name="right_hand">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 -0.04 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.08 0.10 0.04"/>
      </geometry>
      <origin xyz="0 -0.04 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.10 0.04"/>
      </geometry>
      <origin xyz="0 -0.04 0" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="right_wrist_pitch" type="revolute">
    <parent link="right_wrist"/>
    <child link="right_hand"/>
    <origin xyz="0 -0.06 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="15.0" velocity="5.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <!-- Right EE -->
  <link name="right_ee"/>
  <joint name="right_ee_joint" type="fixed">
    <parent link="right_hand"/>
    <child link="right_ee"/>
    <origin xyz="0 -0.14 0" rpy="0 0 0"/>
  </joint>

</robot>
