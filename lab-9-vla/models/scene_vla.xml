<?xml version="1.0" encoding="utf-8"?>
<!-- VLA Integration Scene — Lab 9
     G1 humanoid at a table with 3 colored objects (red cup, blue box, green bottle).
     Cameras: head_cam (egocentric), left_wrist_cam (close-up manipulation).
     Weld constraints (disabled by default) for grasping simulation.
-->
<mujoco model="scene_vla">
  <compiler angle="radian" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.005"/>

  <include file="g1_vla.xml"/>

  <default>
    <default class="object">
      <geom contype="1" conaffinity="1" friction="0.8 0.02 0.001"/>
      <joint damping="0.05" armature="0.001" frictionloss="0.01"/>
    </default>
  </default>

  <asset>
    <texture name="wood" type="2d" builtin="flat" rgb1="0.65 0.45 0.25"
             rgb2="0.55 0.38 0.2" width="256" height="256"/>
    <material name="wood" texture="wood" reflectance="0.1"/>
    <material name="cup_mat" rgba="0.9 0.2 0.2 1"/>
    <material name="box_mat" rgba="0.2 0.5 0.9 1"/>
    <material name="bottle_mat" rgba="0.2 0.8 0.3 1"/>
    <material name="table_mat" rgba="0.75 0.55 0.35 1"/>
  </asset>

  <worldbody>
    <!-- Overhead light for scene illumination -->
    <light name="scene_overhead" pos="0.7 0 3" dir="0 0 -1"
           diffuse="0.9 0.9 0.9" specular="0.4 0.4 0.4" castshadow="true"/>
    <light name="scene_fill" pos="1.5 1.0 2.5" dir="-0.5 -0.5 -1"
           diffuse="0.4 0.4 0.5" specular="0.1 0.1 0.1"/>
    <light name="scene_back" pos="-0.5 -1.0 2.0" dir="0.3 0.5 -1"
           diffuse="0.3 0.3 0.35" specular="0.05 0.05 0.05"/>

    <!-- External third-person camera for visualization -->
    <camera name="external_cam" pos="1.5 1.2 1.8" xyaxes="-0.7 0.7 0 -0.3 -0.3 0.9"
            fovy="60"/>

    <!-- Table -->
    <body name="table" pos="0.7 0.0 0.0">
      <geom name="table_top" type="box" size="0.4 0.4 0.02" pos="0 0 0.74"
            material="table_mat" contype="1" conaffinity="1"/>
      <geom name="table_leg_fl" type="cylinder" size="0.025 0.37"
            pos="0.35 0.35 0.37" rgba="0.6 0.4 0.2 1"/>
      <geom name="table_leg_fr" type="cylinder" size="0.025 0.37"
            pos="0.35 -0.35 0.37" rgba="0.6 0.4 0.2 1"/>
      <geom name="table_leg_bl" type="cylinder" size="0.025 0.37"
            pos="-0.35 0.35 0.37" rgba="0.6 0.4 0.2 1"/>
      <geom name="table_leg_br" type="cylinder" size="0.025 0.37"
            pos="-0.35 -0.35 0.37" rgba="0.6 0.4 0.2 1"/>
    </body>

    <!-- Red cup (cylinder) — free body -->
    <body name="cup" pos="0.65 0.1 0.82">
      <freejoint name="cup_joint"/>
      <geom name="cup_body" type="cylinder" size="0.04 0.07" pos="0 0 0.07"
            class="object" material="cup_mat" mass="0.2"/>
      <geom name="cup_bottom" type="cylinder" size="0.04 0.005" pos="0 0 0.005"
            class="object" material="cup_mat" mass="0.02"/>
      <site name="cup_site" pos="0 0 0.14" size="0.01"/>
    </body>

    <!-- Blue box — free body -->
    <body name="box" pos="0.7 -0.1 0.82">
      <freejoint name="box_joint"/>
      <geom name="box_body" type="box" size="0.05 0.05 0.04" pos="0 0 0.04"
            class="object" material="box_mat" mass="0.3"/>
      <site name="box_site" pos="0 0 0.08" size="0.01"/>
    </body>

    <!-- Green bottle (capsule-like, built from cylinders) — free body -->
    <body name="bottle" pos="0.75 0.0 0.82">
      <freejoint name="bottle_joint"/>
      <geom name="bottle_lower" type="cylinder" size="0.03 0.07" pos="0 0 0.07"
            class="object" material="bottle_mat" mass="0.15"/>
      <geom name="bottle_neck" type="cylinder" size="0.015 0.04" pos="0 0 0.18"
            class="object" material="bottle_mat" mass="0.05"/>
      <geom name="bottle_cap" type="cylinder" size="0.018 0.01" pos="0 0 0.23"
            class="object" material="bottle_mat" mass="0.01"/>
      <site name="bottle_site" pos="0 0 0.14" size="0.01"/>
    </body>

    <!-- Target zone markers (visual only) -->
    <site name="target_left" pos="0.65 0.25 0.77" size="0.03" rgba="1 1 0 0.3"/>
    <site name="target_center" pos="0.70 0.0 0.77" size="0.03" rgba="1 1 0 0.3"/>
    <site name="target_right" pos="0.65 -0.25 0.77" size="0.03" rgba="1 1 0 0.3"/>
  </worldbody>

  <contact>
    <!-- Object-table contacts -->
    <pair geom1="table_top" geom2="cup_body"/>
    <pair geom1="table_top" geom2="cup_bottom"/>
    <pair geom1="table_top" geom2="box_body"/>
    <pair geom1="table_top" geom2="bottle_lower"/>
    <!-- Hand-object contacts -->
    <pair geom1="rh_col" geom2="cup_body"/>
    <pair geom1="rh_col" geom2="box_body"/>
    <pair geom1="rh_col" geom2="bottle_lower"/>
    <pair geom1="lh_col" geom2="cup_body"/>
    <pair geom1="lh_col" geom2="box_body"/>
    <pair geom1="lh_col" geom2="bottle_lower"/>
  </contact>

  <!-- Weld constraints for grasping (disabled by default, enabled via mj_data.eq_active) -->
  <equality>
    <weld name="grasp_cup" body1="right_hand" body2="cup"
          relpose="0 -0.03 0 1 0 0 0" active="false"/>
    <weld name="grasp_box" body1="right_hand" body2="box"
          relpose="0 -0.03 0 1 0 0 0" active="false"/>
    <weld name="grasp_bottle" body1="right_hand" body2="bottle"
          relpose="0 -0.03 0 1 0 0 0" active="false"/>
  </equality>

</mujoco>
